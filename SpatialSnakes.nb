Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HighCurvatureFunc", "[", 
    RowBox[{
    "MorphologicalEdgeDetectionOrdered_", ",", "OrientationConnectedComp_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DevNo", "=", "3"}], ",", 
       RowBox[{"nMax", "=", "15"}], ",", "A1s", ",", "WeightedAveragTangent", 
       ",", "DeviationHorizontality", ",", "HighCurvature", ",", 
       RowBox[{"orientations", "=", 
        RowBox[{
         RowBox[{"Dimensions", "[", "os", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WeightedAveragTangent", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"GaussianFilter", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MorphologicalEdgeDetectionOrdered", "[", 
                RowBox[{"[", "K", "]"}], "]"}], "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", "10", ",", "1", 
              ",", 
              RowBox[{"Padding", "->", "\"\<Periodic\>\""}]}], "]"}], ",", 
            RowBox[{"GaussianFilter", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MorphologicalEdgeDetectionOrdered", "[", 
                RowBox[{"[", "K", "]"}], "]"}], "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "3"}], "]"}], "]"}], ",", "10", ",", "1", 
              ",", 
              RowBox[{"Padding", "->", "\"\<Periodic\>\""}]}], "]"}]}], "}"}],
           "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"K", ",", 
           RowBox[{
           "Length", "[", "MorphologicalEdgeDetectionOrdered", "]"}]}], 
          "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"A1s", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"Cos", "[", "#", "]"}], ",", 
            RowBox[{"Sin", "[", "#", "]"}]}], "}"}], "&"}], ",", 
         RowBox[{"Range", "[", 
          RowBox[{"0", ",", 
           RowBox[{
            RowBox[{"2", "\[Pi]"}], "-", 
            RowBox[{"2", 
             RowBox[{"\[Pi]", "/", "orientations"}]}]}], ",", 
           RowBox[{"2", 
            RowBox[{"\[Pi]", "/", "orientations"}]}]}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"DeviationHorizontality", "=", " ", 
       RowBox[{
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ArcCos", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#1", ".", 
                 RowBox[{
                  RowBox[{"A1s", "[", 
                   RowBox[{"[", 
                    RowBox[{"OrientationConnectedComp", "[", 
                    RowBox[{"[", "K", "]"}], "]"}], "]"}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"2", ";;", "3"}], "]"}], "]"}]}], ")"}], "/", 
               RowBox[{"Norm", "[", "#1", "]"}]}], "]"}], "&"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"WeightedAveragTangent", "[", 
               RowBox[{"[", "K", "]"}], "]"}], ",", 
              RowBox[{"MorphologicalEdgeDetectionOrdered", "[", 
               RowBox[{"[", "K", "]"}], "]"}]}], "}"}], ",", "1"}], "]"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"K", ",", 
            RowBox[{
            "Length", "[", "MorphologicalEdgeDetectionOrdered", "]"}]}], 
           "}"}]}], "]"}], "//", "N"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"HighCurvature", " ", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Erosion", "[", 
           RowBox[{
            RowBox[{"Dilation", "[", 
             RowBox[{"#", ",", "nMax"}], "]"}], ",", "nMax"}], "]"}], "&"}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Clip", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Sign", "[", 
                  RowBox[{"#", "-", 
                   RowBox[{"DevNo", "*", 
                    FractionBox[
                    RowBox[{"2", "\[Pi]"}], "orientations"]}]}], "]"}], "+", 
                 "1"}], ")"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "1"}], "}"}]}], "]"}], "&"}], ",", 
            "DeviationHorizontality"}], "]"}], "*", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Clip", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"Sign", "[", 
                   RowBox[{"#", "-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"orientations", "/", "2"}], "-", "DevNo"}], ")"}],
                     "*", 
                    FractionBox[
                    RowBox[{"2", "\[Pi]"}], "orientations"]}], ")"}]}], 
                   "]"}]}], "+", "1"}], ")"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "1"}], "}"}]}], "]"}], "&"}], ",", 
            "DeviationHorizontality"}], "]"}]}]}], "\[IndentingNewLine]", 
        "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "HighCurvature", "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}]], "Input",
