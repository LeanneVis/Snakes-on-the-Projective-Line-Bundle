             RowBox[{"-", "1"}]]}], ",", " ", 
           SuperscriptBox[
            SubscriptBox["C", 
             SubscriptBox["g", "0"]], "0"]}], "*)"}], "\n", 
         RowBox[{"Cold", "=", 
          RowBox[{"{", "}"}]}], ";", "\n", 
         RowBox[{"Cnew", "=", 
          RowBox[{"{", "g", "}"}]}], ";", "\n", 
         RowBox[{"newAdded", "=", 
          RowBox[{"{", "g", "}"}]}], ";", "\n", 
         RowBox[{"(*", 
          RowBox[{"Morphological", " ", "Convolutions"}], "*)"}], "\n", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{"newAdded", "!=", 
            RowBox[{"{", "}"}]}], ",", "\n", 
