     RowBox[{"idata", ",", "ii", ",", "res"}], "}"}], ",", 
    RowBox[{
     RowBox[{"idata", "=", 
      RowBox[{"ImageData", "[", 
       RowBox[{"ImagePad", "[", 
        RowBox[{"im", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ii", "=", 
      RowBox[{"Replace", "[", 
       RowBox[{"iter", ",", 
        RowBox[{
         RowBox[{"Except", "[", 
          RowBox[{"_Integer", "?", "NonNegative"}], "]"}], "->", 
         RowBox[{"10", "^", "9"}]}], ",", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"res", "=", 
      RowBox[{"morphologicalThinning3DC", "[", 
       RowBox[{"idata", ",", "ii"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ImagePad", "[", 
      RowBox[{
       RowBox[{"Image3D", "[", 
        RowBox[{"res", ",", "\"\<Bit\>\""}], "]"}], ",", 
       RowBox[{"-", "1"}]}], "]"}]}]}], "]"}]}]}], "Input",
