                    RowBox[{"#", "[", 
                    RowBox[{"[", "3", "]"}], "]"}], "]"}], "]"}], "]"}]}], 
                   "]"}]}], "]"}], "&"}], ",", "newAdded"}], "]"}]}], ";", 
