Cell[CellGroupData[{

Cell["Show Fourier spectrum", "Subsection",
 CellChangeTimes->{{3.6699517247517176`*^9, 
  3.669951732405588*^9}},ExpressionUUID->"162ede06-e74a-4b4a-adc2-\
ab734e8ee754"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "function", " ", "assumes", " ", "the", " ", "image", " ", 
    "is", " ", "square"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"CenteredFourier", "[", "im_", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"size", "=", 
        RowBox[{"Length", "[", "im", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"RotateRight", "[", 
       RowBox[{
        RowBox[{"Fourier", "[", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"im", ",", 
           RowBox[{"Floor", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"size", ",", "size"}], "}"}], "/", "2"}], "]"}]}], 
          "]"}], "]"}], ",", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"size", ",", "size"}], "}"}], "/", "2"}], "]"}]}], "]"}]}],
      "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CenteredInverseFourier", "[", "im_", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"size", "=", 
        RowBox[{"Length", "[", "im", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"RotateRight", "[", 
       RowBox[{
        RowBox[{"InverseFourier", "[", 
         RowBox[{"RotateLeft", "[", 
          RowBox[{"im", ",", 
           RowBox[{"Floor", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"size", ",", "size"}], "}"}], "/", "2"}], "]"}]}], 
          "]"}], "]"}], ",", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"size", ",", "size"}], "}"}], "/", "2"}], "]"}]}], "]"}]}],
      "\[IndentingNewLine]", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.669951810843202*^9, 3.669951855308711*^9}, {
  3.6699519410302143`*^9, 3.669951941092684*^9}, {3.9403295770739517`*^9, 
  3.9403295880117073`*^9}},
 CellLabel->"In[89]:=",ExpressionUUID->"dee3583e-944b-439f-b1a9-5b0781cc527b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cwsf", " ", "=", " ", 
   RowBox[{"Re", "/@", 
    RowBox[{"CenteredFourier", "/@", "cws"}]}]}], ";"}]], "Input",
