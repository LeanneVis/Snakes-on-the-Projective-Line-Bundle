      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"The", " ", 
        RowBox[{"stack", ":"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"stack", "=", 
       RowBox[{"GenerateKernelSetGabor", "[", 
        RowBox[{"A", ",", "k0", ",", "a", ",", 
         RowBox[{"Round", "[", 
          RowBox[{"\[Pi]", "/", "s\[CurlyPhi]"}], "]"}], ",", "size", ",", 
         "matrixCoordinatesQ"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"periodicity", "\[Equal]", 
