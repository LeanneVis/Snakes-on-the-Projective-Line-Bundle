   RowBox[{"AbsoluteTiming", "[", "\n", 
    RowBox[{"Monitor", "[", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Position", "[", 
