                    RowBox[{"cb", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "==", "1"}], ",", 
                    RowBox[{
                    RowBox[{"adj", "[", 
                    RowBox[{"[", 
                    RowBox[{"26", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
                    "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", "conn26"}], "}"}]}], "]"}]}], "]"}], 
                 ";", "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"cb", "[", 
                    RowBox[{"[", "27", "]"}], "]"}], "==", "1"}], ",", 
                   RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"cb", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "==", "1"}], ",", 
                    RowBox[{
                    RowBox[{"adj", "[", 
                    RowBox[{"[", 
