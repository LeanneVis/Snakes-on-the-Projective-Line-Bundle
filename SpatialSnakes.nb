                    "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", "conn27"}], "}"}]}], "]"}]}], "]"}], 
                 ";", "\[IndentingNewLine]", 
                 RowBox[{"pp", "=", 
                  RowBox[{"Complement", "[", 
                   RowBox[{
                    RowBox[{"rng", " ", "cb"}], ",", 
                    RowBox[{"{", "0", "}"}]}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"adj", "=", 
                  RowBox[{"adj", "[", 
                   RowBox[{"[", 
                    RowBox[{"pp", ",", "pp"}], "]"}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"adj", "=", 
                  RowBox[{"adj", "+", 
                   RowBox[{"Transpose", "[", "adj", "]"}]}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"adj", "=", 
                  RowBox[{"adj", ".", "adj"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
