                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Cos", "[", 
                    RowBox[{
                    RowBox[{"-", "\[Theta]"}], "+", 
                    RowBox[{"\[Pi]", "/", "2"}]}], "]"}], ",", 
                    RowBox[{"-", 
                    RowBox[{"Sin", "[", 
                    RowBox[{
                    RowBox[{"-", "\[Theta]"}], "+", 
