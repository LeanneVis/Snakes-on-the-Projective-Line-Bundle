                  RowBox[{"Floor", "[", 
                   RowBox[{"dim", "/", "2"}], "]"}], "-", 
                  RowBox[{"(", 
                   RowBox[{"1", "-", 
                    RowBox[{"2", "*", 
                    RowBox[{"Mod", "[", 
                    RowBox[{
                    RowBox[{"dim", "/", "2"}], ",", "1"}], "]"}]}]}], 
                   ")"}]}]}], "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
