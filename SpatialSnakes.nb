                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"yy", ",", "xx"}], "}"}], "/", "a"}], ")"}]}], 
                    ")"}]}], "]"}], 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{"1", "/", "2"}], ")"}]}], " ", 
                    RowBox[{
                    RowBox[{"Norm", "[", 
                    RowBox[{"(", 
                    RowBox[{"A", ".", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"yy", ",", "xx"}], "}"}], "/", "a"}], ")"}]}], 
                    ")"}], "]"}], "^", "2"}]}], "]"}]}]}], 
                "\[IndentingNewLine]", "]"}], ",", 
