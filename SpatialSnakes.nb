        RowBox[{"{", 
         RowBox[{"a", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"n\[Theta]", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"dim", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"matQ", ",", 
          RowBox[{"True", "|", "False"}]}], "}"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
        "{", "\[IndentingNewLine]", "d\[Theta]", "\[IndentingNewLine]", "}"}],
         ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"d\[Theta]", "=", 
          RowBox[{
           RowBox[{"(", "\[Pi]", ")"}], "/", "n\[Theta]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"0.00000000001", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", 
             RowBox[{"(", 
